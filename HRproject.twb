          </datasources>
          <datasource-dependencies datasource='federated.1wm7pwx1r53w88198we090r7eg4o'>
            <column caption='Clean Term Reason' datatype='string' name='[Calculation_1080053254946820]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Termd] = 1 THEN [TermReason]&#13;&#10;ELSE &quot;Still Employed&quot;&#13;&#10;END' />
            </column>
            <column caption='Dateof Hire' datatype='date' name='[DateofHire]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Department]' role='dimension' type='nominal' />
